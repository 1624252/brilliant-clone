# Firebase web app configuration.
#
# Setup:
#   1. Copy this file to ".env" (which is git-ignored).
#   2. Fill each value from the Firebase console:
#      Project settings > General > Your apps > Web app > SDK setup and config.
#
# These VITE_-prefixed values are bundled into client code. They are not secret
# (app security is enforced by Firebase Auth + Firestore rules), but we keep the
# real values out of the repo by convention.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Supabase Edge Function used as the server-side OpenAI proxy for the Simulation
# Studio. These are browser-visible values. The anon key is public by design; the
# OpenAI key must stay in Supabase secrets, not here.
VITE_SUPABASE_GENERATE_SIMULATION_URL=
VITE_SUPABASE_ANON_KEY=

# Do NOT put OpenAI or other private API keys in this frontend .env file.
# For the Simulation Studio's server-side AI proxy, set it as a Supabase secret:
#   npx supabase secrets set OPENAI_API_KEY=sk-...
